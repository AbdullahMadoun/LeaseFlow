# ============================================================
# LeaseFlow Orchestrator — .env.example
# Copy to .env and fill in secrets. Do NOT commit real values.
# ============================================================

# ---- Supabase ----
SUPABASE_URL=https://gbdnlnoqkdislrhvfxol.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=
LEASEFLOW_BUCKET=loan-documents
SIGNED_URL_TTL_S=300

# ---- MiniMax LLM (OpenAI-compatible) ----
LLM_BASE_URL=https://api.minimax.io/v1
MINIMAX_API_KEY=
LLM_MODEL=MiniMax-M2.7
LLM_TIMEOUT_S=120
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.2

# ---- Google Maps reviews agent (Apify) ----
APIFY_TOKEN=
APIFY_BASE_URL=https://api.apify.com/v2
APIFY_TIMEOUT_S=180
APIFY_PLACES_ACTOR_ID=compass/crawler-google-places
APIFY_REVIEWS_ACTOR_ID=compass/google-maps-reviews-scraper
GOOGLE_REVIEWS_LOCATION_QUERY=Saudi Arabia
GOOGLE_REVIEWS_COUNTRY_CODE=sa
GOOGLE_REVIEWS_LANGUAGE=en
GOOGLE_REVIEWS_MAX_PLACES=5
GOOGLE_REVIEWS_MAX_REVIEWS=40

# ---- Existing analyst service (POS / Financial engine) ----
ANALYST_API_URL=http://analyst:8080
ANALYST_API_KEY=
ANALYST_POLL_INTERVAL_S=5
ANALYST_TIMEOUT_S=1800

# ---- Orchestrator ----
# decision_mode: 'guardrail' (LLM can only downgrade) or 'llm_primary' (LLM is the decider)
DECISION_MODE=guardrail
PIPELINE_CONCURRENCY=4
DIM_TASK_TIMEOUT_S=1800

# ---- Risk snapshot scheduler ----
# 1800 = 30 min (demo). Raise to 21600 (6h) in prod.
RISK_SNAPSHOT_INTERVAL_S=1800
RISK_SNAPSHOT_ON_STARTUP=true

# ---- Notifications ----
RESEND_API_KEY=
NOTIFICATIONS_FROM=LeaseFlow <no-reply@leaseflow.demo>
NOTIFICATIONS_ENABLED=true

# ---- Stream Payments (stream.sa) ----
STREAM_BASE_URL=https://stream-app-service.streampay.sa
STREAM_API_KEY=
STREAM_API_SECRET=
STREAM_X_API_KEY=
STREAM_WEBHOOK_SECRET=
STREAM_SANDBOX_PHONE=
STREAM_CONSUMER_TYPE=INDIVIDUAL

# ---- Service ----
BIND_HOST=0.0.0.0
BIND_PORT=8000
CORS_ORIGINS=*

# ---- Logging ----
LOG_LEVEL=INFO
ENV=development

# Demo replay — see stream-hacka/.env.example for full explanation.
DEMO_MODE=false
