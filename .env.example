# ============================================================
# Top-level .env.example for stream-hacka (LeaseFlow full stack)
# Copy to .env (DO NOT COMMIT) and fill in secrets.
# ============================================================

# ---- Supabase ----
SUPABASE_URL=https://gbdnlnoqkdislrhvfxol.supabase.co
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=
LEASEFLOW_BUCKET=loan-documents

# ---- MiniMax ----
MINIMAX_API_KEY=
LLM_MODEL=MiniMax-M2.7
LLM_BASE_URL=https://api.minimax.io/v1

# ---- Google Maps reviews agent (Apify) ----
APIFY_TOKEN=
APIFY_BASE_URL=https://api.apify.com/v2
APIFY_PLACES_ACTOR_ID=compass/crawler-google-places
APIFY_REVIEWS_ACTOR_ID=compass/google-maps-reviews-scraper
APIFY_TIMEOUT_S=180
GOOGLE_REVIEWS_LOCATION_QUERY=Saudi Arabia
GOOGLE_REVIEWS_COUNTRY_CODE=sa
GOOGLE_REVIEWS_LANGUAGE=en
GOOGLE_REVIEWS_MAX_PLACES=5
GOOGLE_REVIEWS_MAX_REVIEWS=40

# ---- Orchestrator ----
DECISION_MODE=guardrail              # guardrail | llm_primary
PIPELINE_CONCURRENCY=4
RISK_SNAPSHOT_INTERVAL_S=1800        # demo 30min; prod 21600 (6h)
RISK_SNAPSHOT_ON_STARTUP=true
LEASEFLOW_DEV_FIXTURES=false         # true mounts POST /dev/generate-fixtures
                                     # for one-click fake doc uploads

# Demo replay mode — when true, /analyze/start replays a cached decision
# for known demo merchant emails (ghazal.abdulrazzak@gmail.com, gzrazak@gmail.com,
# a-madoun@hotmail.com). Real upload + classifier + RLS still run; only the
# extraction + dims + synthesis phases are substituted. Off in production.
DEMO_MODE=false
CORS_ORIGINS=*
ENV=production
LOG_LEVEL=INFO
ORCHESTRATOR_BIND_PORT=8000

# ---- Analyst (existing pos-analyst engine) ----
ANALYST_API_KEY=
ANALYST_BIND_PORT=8080
POS_HOST_WORK_DIR=/var/pos-analyst

# ---- Notifications ----
RESEND_API_KEY=
NOTIFICATIONS_FROM=LeaseFlow <no-reply@leaseflow.demo>
NOTIFICATIONS_ENABLED=true

# ---- Stream Payments (stream.sa) ----
# Get these from the Stream dashboard: Settings → API Keys (key + secret pair)
# and Settings → Webhooks (for the signing secret).
STREAM_BASE_URL=https://stream-app-service.streampay.sa
STREAM_API_KEY=
STREAM_API_SECRET=
# Optional override — if unset, computed at boot as base64(API_KEY:API_SECRET)
STREAM_X_API_KEY=
# HMAC-SHA256 secret for verifying inbound webhook signatures. If empty,
# signatures are NOT verified (accept-all — demo only).
STREAM_WEBHOOK_SECRET=
# Sandbox constraint: consumer phone_number must match the Stream-registered
# phone of the org owner. Set this to your phone (E.164 format) for the demo;
# leave empty in production.
STREAM_SANDBOX_PHONE=
# Default consumer_type for newly-registered merchants. INDIVIDUAL skips
# Stream's address + vat_number requirement. Flip to BUSINESS in prod.
STREAM_CONSUMER_TYPE=INDIVIDUAL
